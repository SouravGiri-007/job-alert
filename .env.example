# Smart Job Alert - Environment Configuration
# Copy this file to .env and fill in your values

# App
SECRET_KEY=change-this-to-a-random-secret
APP_URL=http://localhost:5000

# Admin (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# SMTP (for sending emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Smart Job Alert

# Scheduler (24h format)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

JOB_ALERT_DATABASE_URL=postgresql://postgres:sxxxxxxxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres
