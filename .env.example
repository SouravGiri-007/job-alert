# Smart Job Alert - Environment Configuration
# Copy this file to .env and fill in your values

# App
SECRET_KEY=change-this-to-a-random-secret
APP_URL=http://localhost:5000

# Admin (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database (leave blank for SQLite, or use PostgreSQL)
JOB_ALERT_DATABASE_URL=

# Resend (for sending emails via API — replace SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=Smart Job Alert
EMAIL_WORKERS=4

# RapidAPI (for job scraping APIs)
RAPIDAPI_KEY=
RAPIDAPI_INDIANJOBS_KEY=
RAPIDAPI_LINKEDIN_HOST=linkedin-job-search-api.p.rapidapi.com
RAPIDAPI_INDIANJOBS_HOST=indian-jobs-api.p.rapidapi.com

# Scheduler (24h format)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Logging (optional)
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
